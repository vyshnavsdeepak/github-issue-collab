# GitHub App credentials
# Get these from: GitHub → Settings → Developer settings → GitHub Apps → Your App
GITHUB_APP_ID=12345

# Option A: Paste the private key directly (dotenv supports multi-line when quoted)
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEowIBAAKCAQEA...
-----END RSA PRIVATE KEY-----"

# Option B: Point to the downloaded .pem file
# GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# Server port
PORT=3000
